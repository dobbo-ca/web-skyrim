---
import '../styles/global.css';
import Nav from '../components/Nav';

interface Props {
  title: string;
  currentSection?: 'alchemy' | 'enchanting' | 'home';
}
const { title, currentSection = 'home' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <Nav client:load currentSection={currentSection} />
    <slot />
  </body>
</html>
